# Google Sheet CSV URLs
# To get these:
# 1. Open your Google Sheet
# 2. File → Share → Publish to web
# 3. Select the sheet tab → Choose "Comma-separated values (.csv)"
# 4. Click "Publish" and copy the URL
#
# Format: https://docs.google.com/spreadsheets/d/e/SPREADSHEET_ID/pub?gid=TAB_GID&single=true&output=csv
GOOGLE_SHEET_FINTECH_URL=
GOOGLE_SHEET_INVESTORS_URL=
GOOGLE_SHEET_BANKS_URL=
GOOGLE_SHEET_SECURITIES_URL=
GOOGLE_SHEET_INSURANCE_URL=
GOOGLE_SHEET_NEOBANKS_URL=

# Editorial Google Sheet (team-managed content — ONE spreadsheet, multiple tabs)
# Base URL: File → Share → Publish to web → Entire Document → CSV
GOOGLE_SHEET_EDITORIAL_BASE=
# JSON map of tab name → gid number (find gid in the sheet URL after #gid=)
GOOGLE_SHEET_EDITORIAL_GIDS={"unicorns":"0","ratings":"123","milestones":"456","market_size":"789","vifc_incentives":"101","vifc_entities":"102","investor_costs":"103","risks":"104","calendar":"105","carbon_timeline":"106","carbon_credits":"107","dfi":"108","commodity_products":"109","commodity_brokers":"110","quarterly_investment":"111","startup_stages":"112","investor_countries":"113","related_links":"114","rating_agencies":"115","why_vietnam":"116"}

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Session secret (change in production)
SESSION_SECRET=

# MoMo Payment Gateway
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_AMOUNT_VND=250000

# Upstash Redis (via Vercel Marketplace)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Cron Job secret (set in Vercel dashboard)
CRON_SECRET=
