# Google Sheet CSV URLs
# To get these:
# 1. Open your Google Sheet
# 2. File → Share → Publish to web
# 3. Select the sheet tab → Choose "Comma-separated values (.csv)"
# 4. Click "Publish" and copy the URL
#
# Format: https://docs.google.com/spreadsheets/d/e/SPREADSHEET_ID/pub?gid=TAB_GID&single=true&output=csv
GOOGLE_SHEET_FINTECH_URL=
GOOGLE_SHEET_INVESTORS_URL=
GOOGLE_SHEET_BANKS_URL=
GOOGLE_SHEET_SECURITIES_URL=
GOOGLE_SHEET_INSURANCE_URL=

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Session secret (change in production)
SESSION_SECRET=

# MoMo Payment Gateway
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_AMOUNT_VND=250000

# Upstash Redis (via Vercel Marketplace)
KV_REST_API_URL=
KV_REST_API_TOKEN=
